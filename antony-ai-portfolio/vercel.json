{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/antony-ai-portfolio/browser",
  "devCommand": "ng serve",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}